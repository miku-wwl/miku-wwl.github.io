---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TerminalWindow from '../components/TerminalWindow.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`404 | ${SITE_TITLE}`} description="Page not found." />
	</head>
	<body>
		<Header />
		<main>
			<section class="section not-found">
				<p class="eyebrow">~/404 $ cat missing-page.log</p>
				<TerminalWindow title="missing-page.log">
					<p class="status mono">error: page not found</p>
					<h1>404</h1>
					<p>
						The page you requested does not exist or may have moved.
					</p>
					<div class="actions">
						<a class="btn primary" href="/">go home →</a>
						<a class="btn" href="/blog">browse the blog</a>
					</div>
				</TerminalWindow>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.not-found {
		min-height: calc(100vh - 18rem);
		display: grid;
		align-items: center;
	}
	.status {
		margin: 0 0 0.75rem;
		color: var(--danger, #ff7b72);
	}
	h1 {
		margin: 0 0 0.5rem;
		font-size: clamp(3rem, 8vw, 5rem);
		line-height: 1;
	}
	.actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
		margin-top: 1.5rem;
	}
</style>
