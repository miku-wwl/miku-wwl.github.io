---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TerminalWindow from '../components/TerminalWindow.astro';
import MvpBadge from '../components/MvpBadge.astro';
import { SITE_TITLE, SOCIAL_LINKS } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`About | ${SITE_TITLE}`} description="About Weilai Wang — senior software engineer focused on backend and cloud-native engineering." />
	</head>
	<body>
		<Header />
		<main>
			<section class="section">
				<p class="eyebrow">~/about.md $ cat ./bio</p>
				<TerminalWindow title="about.md">
					<h1>About me</h1>
					<p>
						I am an Auckland-based software engineer with 4+ years of professional experience at Huawei,
						focused on backend systems, distributed services, Kubernetes-based applications, and cloud-native
						engineering.
					</p>
					<p>
						My engineering background includes building and maintaining Java/Spring Boot microservices, working
						with Kubernetes deployments, defining cross-service interfaces, supporting monitoring and troubleshooting
						workflows, and collaborating across teams in production-oriented software environments. I also completed
						a Java backend internship at OKX, where I gained exposure to event-driven architecture and high-performance
						backend systems in a core matching system team.
					</p>
					<p>
						I am currently strengthening my platform engineering and cloud reliability skill set through hands-on work
						with AWS, Azure, Kubernetes, Terraform, CI/CD, observability, monitoring, and root-cause analysis. I am
						particularly interested in backend, cloud-native, SRE, and platform engineering roles where reliability,
						automation, and distributed systems matter.
					</p>

					<div class="mvp-block-wrap">
						<MvpBadge variant="block" />
					</div>
				</TerminalWindow>
			</section>

			<section class="section">
				<p class="eyebrow">~/about $ ls ./contact</p>
				<TerminalWindow title="contact">
					<ul class="contact-list">
						{SOCIAL_LINKS.map((s) => (
							<li>
								<span class="key mono">{s.label.toLowerCase()}</span>
								<a href={s.href} target={s.icon === 'mail' ? undefined : '_blank'} rel="noopener noreferrer">{s.handle}</a>
							</li>
						))}
						<li>
							<span class="key mono">phone</span>
							<a href="tel:+642902748387">(+64) 29 027 48387</a>
						</li>
					</ul>
				</TerminalWindow>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.mvp-block-wrap { margin: 1.25rem 0 0.25rem; }
	.contact-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		grid-template-columns: max-content 1fr;
		gap: 0.5rem 1.25rem;
		font-family: var(--font-mono);
	}
	.contact-list .key { color: var(--prompt); }
	.contact-list .key::after { content: ':'; color: var(--text-muted); margin-left: 0.1rem; }
</style>
