---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MvpBadge from '../components/MvpBadge.astro';
import { SITE_TITLE } from '../consts';

const certs = [
	{
		name: 'Microsoft Certified: Azure Solutions Architect Expert',
		issuer: 'Microsoft Learn',
		icon: 'AZ',
		tone: 'azure',
		href: 'https://learn.microsoft.com/en-us/users/weilaiwang-7477/credentials/3b9265225e0641d',
	},
	{
		name: 'AWS Certified Solutions Architect - Professional',
		issuer: 'Amazon Web Services',
		icon: 'AWS',
		tone: 'aws',
		href: 'https://www.credly.com/badges/00a8748b-01ea-41bf-bb21-54fa628be79e/linked_in_profile',
	},
	{
		name: 'Microsoft Certified: Azure Administrator Associate',
		issuer: 'Microsoft Learn',
		icon: 'AZ',
		tone: 'azure',
		href: 'https://learn.microsoft.com/en-us/users/weilaiwang-7477/credentials/5d434fa19a5220b7',
	},
	{
		name: 'AWS Certified Developer - Associate',
		issuer: 'Amazon Web Services',
		icon: 'AWS',
		tone: 'aws',
		href: 'https://www.credly.com/badges/2dfaf594-6b11-4d74-bee7-d3d1dfd30a78/public_url',
	},
	{
		name: 'Certified Kubernetes Application Developer',
		issuer: 'The Linux Foundation / CNCF',
		icon: 'K8S',
		tone: 'k8s',
		href: 'https://www.credly.com/earner/earned/badge/05fc9907-a20d-4bfe-b341-f8ca8e81b5a0',
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Certifications | ${SITE_TITLE}`} description="Certifications and recognition held by Weilai Wang." />
	</head>
	<body>
		<Header />
		<main>
			<section class="section">
				<p class="eyebrow">~/certifications $ ls -1</p>
				<h1>Certifications &amp; recognition</h1>
				<p class="muted">Verified cloud, Kubernetes, and platform engineering credentials.</p>
			</section>

			<section class="section">
				<p class="eyebrow">~/awards $ cat ./lift-scholarship.txt</p>
				<MvpBadge variant="block" />
			</section>

			<section class="section">
				<p class="eyebrow">~/certifications $ tree --links</p>
				<ul class="cert-grid">
					{certs.map((cert) => (
						<li>
							<a class="cert" href={cert.href} target="_blank" rel="noopener noreferrer">
								<span class={`cert-mark ${cert.tone}`} aria-hidden="true">{cert.icon}</span>
								<span class="cert-copy">
									<strong>{cert.name}</strong>
									<span class="issuer mono">{cert.issuer}</span>
								</span>
								<span class="cert-arrow" aria-hidden="true">→</span>
							</a>
						</li>
					))}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.cert-grid {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.9rem;
	}
	@media (max-width: 700px) { .cert-grid { grid-template-columns: 1fr; } }

	.cert {
		min-height: 92px;
		display: grid;
		grid-template-columns: 52px 1fr auto;
		align-items: center;
		gap: 0.9rem;
		padding: 0.95rem 1rem;
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
		box-shadow: var(--shadow-1);
		color: var(--text);
		text-decoration: none;
		transition: border-color 120ms ease, transform 120ms ease, box-shadow 120ms ease;
	}
	.cert:hover {
		border-color: var(--accent);
		transform: translateY(-2px);
		box-shadow: var(--glow);
		text-decoration: none;
	}
	.cert-mark {
		display: grid;
		place-items: center;
		width: 52px;
		height: 52px;
		border-radius: 14px;
		border: 1px solid var(--border);
		font-family: var(--font-mono);
		font-size: 0.9rem;
		font-weight: 800;
		letter-spacing: 0;
	}
	.cert-mark.aws {
		color: #111827;
		background: linear-gradient(135deg, #ff9900, #ffd36a);
		border-color: rgba(255, 153, 0, 0.45);
	}
	.cert-mark.azure {
		color: #ffffff;
		background: linear-gradient(135deg, #0078d4, #50b4ff);
		border-color: rgba(0, 120, 212, 0.45);
	}
	.cert-mark.k8s {
		color: #ffffff;
		background: linear-gradient(135deg, #326ce5, #5ad0ff);
		border-color: rgba(50, 108, 229, 0.45);
	}
	.cert-copy {
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
		min-width: 0;
	}
	.cert strong {
		display: block;
		line-height: 1.25;
		color: var(--text);
	}
	.issuer {
		color: var(--text-muted);
		font-size: 0.78rem;
	}
	.cert-arrow {
		color: var(--accent);
		font-family: var(--font-mono);
		font-weight: 700;
		transition: transform 120ms ease;
	}
	.cert:hover .cert-arrow { transform: translateX(3px); }
</style>
